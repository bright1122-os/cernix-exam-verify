APP_NAME=CERNIX
APP_KEY=
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
# For local development, SQLite requires no server:
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/to/database.sqlite  (auto-created by migrations)

# For MySQL/MariaDB, comment out sqlite above and use:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cernix
# DB_USERNAME=root
# DB_PASSWORD=

# ── Sessions ──────────────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=240

# ── Remita payment gateway (leave blank for demo mode) ────────────────────────
REMITA_BASE_URL=https://remitademo.net/remita/exapp/api/v1
REMITA_MERCHANT_ID=
REMITA_SERVICE_TYPE_ID=
REMITA_API_KEY=
REMITA_PUBLIC_KEY=
REMITA_SECRET_KEY=
